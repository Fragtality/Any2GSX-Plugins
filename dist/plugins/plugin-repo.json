    },
    "Settings": [
      {
        "Key": "PMDG.777.Option.ClearVehicles",
        "Type": 1,
        "DefaultValue": true,
        "Description": "Clear PMDG Vehicles",
        "Tooltip": "Automatically remove all PMDG Vehicles as they appear."
      },
      {
        "Key": "PMDG.777.Option.ChangePowerType",
        "Type": 1,
        "DefaultValue": true,
        "Description": "Set GPU Plug Type",
        "Tooltip": "Automatically change Power Plug Type between GPU and Jetway depending on the Gate used."
      },
      {
        "Key": "PMDG.777.Option.CargoLights",
        "Type": 1,
        "DefaultValue": true,
        "Description": "Toggle Cargo Lights",
        "Tooltip": "Automatically toggle the Cargo Lights on the 777F when the Doors are operated or GSX becomes active."
      },
      {
        "Key": "PMDG.777.Option.OperateBulk",
        "Type": 1,
        "DefaultValue": true,
        "Description": "Use Bulk Cargo Door",
        "Tooltip": "Also Open or Close the Bulk Cargo Door when the other Cargo Doors are operated (Pax/Cargo)."
      },
      {
        "Key": "PMDG.777.Option.FrontCatering",
        "Type": 5,
        "DefaultValue": -1,
        "EnumValues": {
          "-1": "Default",
          "1": "Door 1R",
          "3": "Door 2R"
        },
        "Description": "Catering: Front Door Mapping",
        "Tooltip": "Configure which PMDG Door is operated when GSX requests Service Door 1 (Front Catering Truck).\nPer Default the 200's and Freighter will use 1R and the 300 the 2R Door.\nNote: Selecting a specific Door here applies to all Variants - so different Profiles for each Variant are needed then."
      },
      {
        "Key": "PMDG.777.Option.FixChocks",
        "Type": 1,
        "DefaultValue": true,
        "Description": "Fix Chocks in Walkaround",
        "Tooltip": "The Plugin will set the PMDG Chocks via L-Var in Walkaround before the Plugin Connection is established.\nThis should prevent the GSX Menu not opening/getting Ready without Brakes or Chocks."
      },
      {
        "Key": "Generic.Var.Engine1.Name",
